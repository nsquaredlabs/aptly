# Ralph Configuration for Aptly Documentation Project

PROJECT_NAME="aptly-docs"
MAX_CALLS_PER_HOUR=100
CLAUDE_TIMEOUT_MINUTES=15
CLAUDE_OUTPUT_FORMAT="json"

# Allow file operations (documentation project)
# More permissive for docs - allow common file/directory operations
ALLOWED_TOOLS="Write,Read,Edit,Bash(ls*),Bash(cat*),Bash(mkdir*),Bash(tree*),Bash(pwd),Bash(echo*),Bash(find*),Bash(grep*),Bash(wc*)"

# Session continuity
SESSION_CONTINUITY=true
SESSION_EXPIRY_HOURS=24

# Documentation-specific settings
PROJECT_TYPE="documentation"
SKIP_BUILD_TESTS=true  # No build/test for docs
