# Aptly Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED
# =============================================================================

# PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://user:pass@localhost/aptly

# API secret for authenticating all requests
# Generate with: openssl rand -base64 32
APTLY_API_SECRET=your-secret-here

# =============================================================================
# OPTIONAL
# =============================================================================

# Redis for rate limiting (disabled without it)
# REDIS_URL=redis://localhost:6379/0

# PII redaction mode: mask, hash, or remove
# PII_REDACTION_MODE=mask

# Compliance frameworks: HIPAA, FINTECH, GDPR, SOC2
# COMPLIANCE_FRAMEWORKS=["HIPAA"]

# Global rate limit (requests per hour)
# RATE_LIMIT_PER_HOUR=1000

# CORS origins
# CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Environment (development, staging, production)
ENVIRONMENT=development

# Logging level (debug, info, warning, error)
LOG_LEVEL=info

# Server port
PORT=8000

# Sentry DSN for error tracking
# SENTRY_DSN=https://xxx@sentry.io/xxx
