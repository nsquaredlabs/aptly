# Aptly Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED
# =============================================================================

# Supabase Configuration
# Get these from your Supabase project settings
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...your-service-role-key

# Redis Configuration
# For local development: redis://localhost:6379/0
# For production: use your Redis provider URL
REDIS_URL=redis://localhost:6379/0

# Admin Secret
# Used for creating customers via POST /v1/admin/customers
# Generate a secure random string (32+ characters)
APTLY_ADMIN_SECRET=your-secure-admin-secret-change-this

# =============================================================================
# OPTIONAL
# =============================================================================

# Environment (development, staging, production)
ENVIRONMENT=development

# Logging level (debug, info, warning, error)
LOG_LEVEL=info

# Server port (default: 8000)
PORT=8000

# Sentry DSN for error tracking (optional)
# SENTRY_DSN=https://xxx@sentry.io/xxx

# Rate limits by plan (requests per hour)
# RATE_LIMIT_FREE=100
# RATE_LIMIT_PRO=1000
# RATE_LIMIT_ENTERPRISE=10000
